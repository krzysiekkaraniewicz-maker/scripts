local function playShakeAnimation(frame, intensity, duration, shakes)
    local originalPos = frame.Position
    local shakeSteps = shakes or 6
    local stepTime = duration / shakeSteps
    
    for i = 1, shakeSteps do
        local offsetX = (i % 2 == 1 and intensity or -intensity) * (1 - (i / shakeSteps) * 0.7)
        local offsetY = math.random(-1, 1) * (intensity * 0.3) * (1 - (i / shakeSteps) * 0.7)
        local stepPos = originalPos + UDim2.new(0, offsetX, 0, offsetY)
        
        task.delay((i - 1) * stepTime, function()
            TweenService:Create(frame, TweenInfo.new(stepTime * 0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Position = stepPos}):Play()
        end)
    end
    
    task.delay(shakeSteps * stepTime, function()
        TweenService:Create(frame, TweenInfo.new(stepTime, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = originalPos}):Play()
    end)
end

local function staggerEntrance(container, duration, offset)
    local children = {}
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("GuiObject") and child.Visible then
            table.insert(children, child)
        end
    end
    
    for i, child in ipairs(children) do
        local origTransparency = child.BackgroundTransparency
        child.BackgroundTransparency = 1
        
        if child:IsA("TextLabel") or child:IsA("TextBox") or child:IsA("TextButton") then
            child.TextTransparency = 1
        end
        
        task.delay((i - 1) * (offset or 0.05), function()
            if not child or not child.Parent then return end
            local tweenInfo = TweenInfo.new(duration or 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            local props = {BackgroundTransparency = origTransparency}
            
            if child:IsA("TextLabel") or child:IsA("TextBox") or child:IsA("TextButton") then
                props.TextTransparency = 0
            end
            
            local originalPos = child.Position
            child.Position = originalPos + UDim2.new(0, 0, 0, 8)
            props.Position = originalPos
            
            TweenService:Create(child, tweenInfo, props):Play()
        end)
    end
end

local function fadeOutAndDestroy(guiObject, duration, callback)
    local children = guiObject:GetDescendants()
    local maxDelay = 0
    
    for _, child in ipairs(children) do
        if child:IsA("GuiObject") and child.Visible then
            local delay = math.random() * 0.15
            maxDelay = math.max(maxDelay, delay + (duration or 0.3))
            local tweenInfo = TweenInfo.new(duration or 0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
            local props = {BackgroundTransparency = 1}
            
            if child:IsA("TextLabel") or child:IsA("TextBox") or child:IsA("TextButton") then
                props.TextTransparency = 1
            end
            
            task.delay(delay, function()
                if child and child.Parent then
                    TweenService:Create(child, tweenInfo, props):Play()
                end
            end)
        end
    end
    
    local mainScale = guiObject:FindFirstChildWhichIsA("UIScale")
    if mainScale then
        task.delay(maxDelay * 0.5, function()
            if mainScale and mainScale.Parent then
                TweenService:Create(mainScale, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {Scale = 0}):Play()
            end
        end)
    end
    
    task.delay(maxDelay + (duration or 0.3) + 0.1, function()
        if guiObject and guiObject.Parent then
            guiObject:Destroy()
        end
        if callback then callback() end
    end)
end

local function createButtonAnim(btn)
    local scale = Instance.new("UIScale", btn)
    btn.MouseEnter:Connect(function() TweenService:Create(scale, animFast, {Scale = 1.02}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(scale, animFast, {Scale = 1}):Play() end)
    btn.MouseButton1Down:Connect(function() TweenService:Create(scale, animFast, {Scale = 0.94}):Play() end)
    btn.MouseButton1Up:Connect(function() TweenService:Create(scale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1.02}):Play() end)
end

