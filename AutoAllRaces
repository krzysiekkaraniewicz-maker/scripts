    -- LOGIKA JAZDY
    local function enableNoclip()
        if noclipConnection then noclipConnection:Disconnect() end
        noclipConnection = RunService.Stepped:Connect(function()
            local character = player.Character
            if character then
                for _, part in ipairs(character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
    end

    local function disableNoclip()
        if noclipConnection then noclipConnection:Disconnect() noclipConnection = nil end
    end

    local function stopDriving()
        disableNoclip()
        if flyMover then flyMover:Destroy() flyMover = nil end
        if flyGyro then flyGyro:Destroy() flyGyro = nil end
        local character = player.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local rp = hrp.AssemblyRootPart or hrp
            rp.AssemblyLinearVelocity = Vector3.zero
            rp.AssemblyAngularVelocity = Vector3.zero
        end
    end

    local function startDriving()
        task.spawn(function()
            enableNoclip()
            while config.isToggled do
                local race = RACES[config.selectedRaceIndex]
                local raceDir = racesFolder:FindFirstChild(race.folder)
                local checkpointsFolder = raceDir and raceDir:FindFirstChild("Checkpoints")

                if not checkpointsFolder then
                    warn("Nie znaleziono checkpointów dla: " .. race.folder)
                    config.isToggled = false
                    break
                end

                local currentLap = 0

                while config.isToggled do
                    if config.targetLaps > 0 and currentLap >= config.targetLaps then break end

                    local character = player.Character
                    local hrp = character and character:FindFirstChild("HumanoidRootPart")
                    if not hrp then config.isToggled = false break end

                    local rootPart = hrp.AssemblyRootPart or hrp

                    if not flyMover or not flyMover.Parent then
                        flyMover = Instance.new("BodyVelocity")
                        flyMover.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                        flyMover.Velocity = Vector3.zero
                        flyMover.Parent = rootPart
                    end

                    if not flyGyro or not flyGyro.Parent then
                        flyGyro = Instance.new("BodyGyro")
                        flyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                        flyGyro.P = 3000
                        flyGyro.D = 500
                        flyGyro.CFrame = rootPart.CFrame
                        flyGyro.Parent = rootPart
                    end

                    currentLap = currentLap + 1

                    for _, cpNum in ipairs(race.checkpoints) do
                        if not config.isToggled then break end
                        local checkpoint = checkpointsFolder:FindFirstChild(tostring(cpNum))
                        if checkpoint then
                            local reached = false
                            while not reached and config.isToggled do
                                RunService.Heartbeat:Wait()
                                if not rootPart or not rootPart.Parent then config.isToggled = false break end

                                local currentPos = rootPart.Position
                                local targetPos = checkpoint.Position + Vector3.new(0, config.heightOffset, 0)
                                local distance = (targetPos - currentPos).Magnitude

                                if distance < 15 then
                                    reached = true
                                    task.wait(0.05)
                                    if race.specialAfter and race.specialAfter[cpNum] then
                                        local spec = race.specialAfter[cpNum]
                                        local prevCp = checkpointsFolder:FindFirstChild(tostring(spec.fromPrev))
                                        if prevCp then
                                            local fwdDir = (checkpoint.Position - prevCp.Position).Unit
                                            local clearTarget = checkpoint.Position + (fwdDir * spec.extraDist) + Vector3.new(0, config.heightOffset, 0)
                                            local cleared = false
                                            while not cleared and config.isToggled do
                                                RunService.Heartbeat:Wait()
                                                if not rootPart or not rootPart.Parent then config.isToggled = false break end
                                                local dist2 = (clearTarget - rootPart.Position).Magnitude
                                                if dist2 < 20 then
                                                    cleared = true
                                                else
                                                    flyMover.Velocity = (clearTarget - rootPart.Position).Unit * config.flySpeed
                                                    flyGyro.CFrame = CFrame.new(rootPart.Position, clearTarget)
                                                end
                                            end
                                        end
                                    end
                                else
                                    flyMover.Velocity = (targetPos - currentPos).Unit * config.flySpeed
                                    flyGyro.CFrame = CFrame.new(currentPos, targetPos)
                                end
                            end
                        end
                    end

                    if not config.isToggled then break end
                end

                stopDriving()

                if config.isToggled and config.isDelayEnabled then
                    local timer = 0
                    while config.isToggled and timer < 15 do
                        task.wait(0.1)
                        timer = timer + 0.1
                    end
                else
                    break
                end
            end

            config.isToggled = false
            startBtnLabel.Text = "START AUTOFARM"
            btnGradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Theme.Accent2),
                ColorSequenceKeypoint.new(1, Theme.Accent1)
            }
            stopDriving()
        end)
    end

    startBtn.MouseButton1Click:Connect(function()
        config.isToggled = not config.isToggled
        if config.isToggled then
            startBtnLabel.Text = "STOP AUTOFARM"
            btnGradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Theme.Danger),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 30, 50))
            }
            startTimer()
            startDriving()
        else
            startBtnLabel.Text = "START AUTOFARM"
            btnGradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Theme.Accent2),
                ColorSequenceKeypoint.new(1, Theme.Accent1)
            }
            stopTimer()
            stopDriving()
        end
    end)
end

