    local function createSlider(title, min, max, default, formatFunc, layoutOrder)
        local section = Instance.new("Frame", contentFrame)
        section.Size = UDim2.new(1, 0, 0, 42)
        section.BackgroundTransparency = 1
        section.LayoutOrder = layoutOrder

        local titleLbl = Instance.new("TextLabel", section)
