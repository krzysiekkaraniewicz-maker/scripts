    -- Funkcja licząca
    local function calculateEarnings()
        local timeStr = timeInput.Text:gsub(",", ".")
        local earnStr = earnInput.Text:gsub(",", ".")
        local multStr = multInput.Text:gsub(",", ".")
        
        -- Support K/M notation in input
        local function parseNumber(s)
            s = s:upper():gsub(",", "")
            local mult = 1
            if s:find("K$") then mult = 1000; s = s:gsub("K$", "") end
            if s:find("M$") then mult = 1000000; s = s:gsub("M$", "") end
            local n = tonumber(s)
            return n and n * mult or nil
        end
        
        local seconds = tonumber(timeStr)
        local earned = parseNumber(earnStr)
        local mult = parseNumber(multStr)
        
        if not seconds or seconds <= 0 then
            resultPerSec.Text = "Raw: 0 cr/sec"
            resultPerHour.Text = "0 cr/hr"
            result12h.Text = "0 cr / 12h"
            result24h.Text = "0 cr / 24h"
            resultMultInfo.Text = "Enter a valid time"
            return
        end
        
        if not earned or earned <= 0 then
            resultPerSec.Text = "Raw: 0 cr/sec"
            resultPerHour.Text = "0 cr/hr"
            result12h.Text = "0 cr / 12h"
            result24h.Text = "0 cr / 24h"
            resultMultInfo.Text = "Enter a valid earned amount"
            return
        end
        
        local perSec = earned / seconds
        local perHour = perSec * 3600
        local per12h = perHour * 12
        local per24h = perHour * 24
        
        local multValue = mult and mult > 0 and mult or 1
        
        resultPerSec.Text = string.format("Raw: %.1f cr/sec", perSec)
        resultPerHour.Text = formatNumber(perHour) .. " cr/hr"
        result12h.Text = formatNumber(per12h) .. " cr / 12h"
        result24h.Text = formatNumber(per24h) .. " cr / 24h"
        
        if mult and mult > 0 and mult ~= 1 then
            local perHourM = perHour * mult
            local per12hM = per12h * mult
            local per24hM = per24h * mult
            resultMultInfo.Text = string.format("With %.1fx mult: %s/hr | %s/12h | %s/24h", mult, formatNumber(perHourM), formatNumber(per12hM), formatNumber(per24hM))
        else
            resultMultInfo.Text = "With mult: enter multiplier above (e.g. 1.5)"
        end
        
        -- Animacja na cr/hr
        TweenService:Create(resultPerHour, animFast, {TextColor3 = Theme.Accent2}):Play()
        task.delay(0.3, function()
            if resultPerHour and resultPerHour.Parent then
                TweenService:Create(resultPerHour, animFast, {TextColor3 = Theme.Accent2}):Play()
            end
        end)
    end

